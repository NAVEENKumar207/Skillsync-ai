# SkillSync AI - Server Environment Variables
# Copy this file to .env and fill in your actual values
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED - Server will not start without these
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skillsync?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here_min_32_chars_recommended
GROQ_API_KEY=your_groq_api_key_here
# Client URL for redirects and CORS
CLIENT_URL=http://localhost:3000